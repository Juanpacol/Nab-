// Nab — Esquema de base de datos (Prisma + PostgreSQL 16 + pgvector)
// Ver plan de arquitectura para el diseño completo.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ============================================================
// Enums
// ============================================================

enum Plan {
  FREE
  BASIC
  PRO
  ULTRA
}

enum RemotePreference {
  ANY
  REMOTE
  HYBRID
  ONSITE
}

enum ApplicationStatus {
  SAVED
  APPLIED
  VIEWED
  INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
}

enum ApplicationMethod {
  AUTO
  MANUAL
  EXTERNAL
}

enum CreditReason {
  SUBSCRIPTION_GRANT
  APPLICATION
  GENERATION
  REFUND
  ADMIN
  TEST_GENERATION
  EVALUATION
  COMPARISON
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  TRIALING
}

enum ChatContext {
  SUPPORT
  CAREER_COACH
}

enum ChatRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

enum JobSourceProvider {
  GREENHOUSE
  LEVER
  ADZUNA
  JSEARCH
  MOCK
  // Vacante propia de una empresa Nab (lado B2B), no ingerida de un proveedor
  // externo — ver Company/CompanyMember y CompanyJobsModule.
  COMPANY
}

enum SyncStatus {
  IDLE
  RUNNING
  ERROR
}

enum CompanyMemberRole {
  OWNER
  RECRUITER
}

enum TechTestStatus {
  GENERATING
  READY
  FAILED
  ARCHIVED
}

enum SubmissionStatus {
  IN_PROGRESS
  SUBMITTED
  EVALUATING
  EVALUATED
  EVALUATION_FAILED
}

// ============================================================
// Usuario, perfil y autenticación
// ============================================================

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String?
  passwordHash    String?
  avatarUrl       String?
  plan            Plan      @default(FREE)
  creditsRemaining Int      @default(5) // caché denormalizado; la fuente de verdad es CreditLedger
  emailVerifiedAt DateTime?
  expoPushToken   String?   // token de Expo Notifications (app móvil, Fase 7)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  profile            Profile?
  resumes            Resume[]
  coverLetters       CoverLetter[]
  applications       Application[]
  subscription       Subscription?
  creditLedger       CreditLedger[]
  chatSessions       ChatSession[]
  integrations       Integration[]
  refreshTokens      RefreshToken[]
  verificationTokens VerificationToken[]
  companyMemberships CompanyMember[]
  testSubmissions    TestSubmission[]
  threadsAsCandidate ApplicationThread[] @relation("ThreadCandidate")
  threadMessagesSent ThreadMessage[]     @relation("ThreadMessageSender")

  @@index([email])
}

enum VerificationTokenType {
  EMAIL_VERIFY
  PASSWORD_RESET
}

// Refresh tokens con rotación: se guarda solo el hash para poder revocar.
model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Tokens de un solo uso para verificación de email y reset de contraseña.
model VerificationToken {
  id        String                @id @default(cuid())
  userId    String
  tokenHash String                @unique
  type      VerificationTokenType
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime              @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
}

model Profile {
  id               String           @id @default(cuid())
  userId           String           @unique
  headline         String?
  summary          String?
  skills           String[]
  experienceJson   Json?
  educationJson    Json?
  locations        String[]
  desiredRoles     String[]
  salaryMin        Int?
  salaryMax        Int?
  remotePreference RemotePreference @default(ANY)
  // Agente de auto-aplicación (opt-in): aplica solo si score >= autoApplyMinScore/100,
  // hasta autoApplyMaxPerDay aplicaciones por día. Ver AutoApplyService.
  autoApplyEnabled   Boolean  @default(false)
  autoApplyMinScore  Int      @default(85)
  autoApplyMaxPerDay Int      @default(3)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Integration {
  id          String   @id @default(cuid())
  userId      String
  provider    String // "linkedin" | "indeed" | ...
  oauthTokens Json
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

// ============================================================
// Documentos: CV y cartas de presentación
// ============================================================

model Resume {
  id              String   @id @default(cuid())
  userId          String
  title           String
  contentJson     Json
  isBase          Boolean  @default(false)
  generatedFromId String? // id del Resume base del que se derivó
  jobId           String? // vacante para la que se personalizó
  fileUrl         String? // PDF en S3
  atsScore        Int?
  model           String? // modelo de IA usado en la generación
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications Application[]

  @@index([userId])
}

model CoverLetter {
  id        String   @id @default(cuid())
  userId    String
  jobId     String?
  content   String
  tone      String   @default("professional")
  model     String?
  createdAt DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications Application[]

  @@index([userId])
}

// ============================================================
// Empresas (lado B2B): pruebas técnicas, vacantes propias, dashboard RH
// ============================================================

model Company {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logoUrl     String?
  website     String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members   CompanyMember[]
  jobs      Job[]
  techTests TechTest[]
  threads   ApplicationThread[]

  @@index([slug])
}

// Prueba técnica generada por IA a partir de roleSpec, con rúbrica citada.
// Versionada: regenerar crea una fila nueva con `version` incrementado y
// `parentId` apuntando a la anterior — nunca se sobrescribe una versión ya
// usada por alguna TestSubmission (auditable).
model TechTest {
  id              String         @id @default(cuid())
  companyId       String
  createdByUserId String
  title           String
  roleSpec        String
  version         Int            @default(1)
  parentId        String?
  status          TechTestStatus @default(GENERATING)
  // TestQuestion[] (packages/shared) — inmutable una vez READY.
  questionsJson   Json?
  // { criteria: RubricCriterion[], passThreshold: number } (packages/shared).
  rubricJson      Json?
  model           String?
  generationError String?
  timeLimitMinutes Int?
  passScore       Int            @default(60)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jobs        Job[]
  submissions TestSubmission[]

  @@index([companyId, status])
}

// Respuestas del candidato a una prueba técnica — una por Application
// (@@unique). `jobId` denormalizado para métricas de funnel sin doble join.
model TestSubmission {
  id                String           @id @default(cuid())
  techTestId        String
  applicationId     String           @unique
  userId            String
  jobId             String
  status            SubmissionStatus @default(IN_PROGRESS)
  // TestAnswer[] (packages/shared) — autosave mientras status=IN_PROGRESS.
  answersJson       Json?
  startedAt         DateTime         @default(now())
  submittedAt       DateTime?
  timeSpentSeconds  Int?
  // Incrementado en cada evaluate() — permite refId estable por intento
  // (`{submissionId}#{attempt}`) para re-evaluaciones (fase de evaluación).
  evaluationAttempt Int              @default(0)

  techTest    TechTest    @relation(fields: [techTestId], references: [id])
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  evaluation  CandidateEvaluation?

  @@index([techTestId, status])
  @@index([jobId, status])
  @@index([userId])
}

// Evaluación de una TestSubmission. Bloque IA (aiXxx) INMUTABLE una vez
// escrito — nunca se sobrescribe en un override; bloque RH (overrideXxx)
// separado para auditoría (¿qué dijo la IA vs. qué decidió el humano?).
// `finalScore`/`passed` son el valor EFECTIVO (override ?? ai), denormalizado
// para que el dashboard (fase siguiente) no tenga que resolver la precedencia
// en cada query de métricas.
model CandidateEvaluation {
  id           String    @id @default(cuid())
  submissionId String    @unique
  // CriterionEvaluation[] (packages/shared) — score+justificación+evidencia por criterio.
  aiScoresJson Json?
  aiSummary    String?
  // string[] cada una (packages/shared LlmEvaluation['qualitative']) — antes
  // se descartaban tras generarse, perdiendo justo el "resumen cualitativo
  // con puntos destacables" que es el diferenciador de producto.
  aiStrengths  Json?
  aiWeaknesses Json?
  aiHighlights Json?
  aiTotalScore Int?
  aiModel      String?
  evaluatedAt  DateTime?
  // El propio LLM se auto-reporta si sospecha que el candidato intentó
  // manipular su evaluación (ver evaluation-generation.service.ts). Cuando es
  // true, `finalScore`/`passed` quedan en null hasta que RH revise
  // manualmente — la verificación de citas por substring solo prueba que una
  // cita EXISTE en la respuesta real, no que sea evidencia técnica legítima
  // (un candidato podría lograr que el LLM cite su propio texto de inyección
  // como "evidencia"), así que este flag es el único backstop real.
  injectionSuspected Boolean @default(false)

  overrideScoresJson  Json?
  overrideTotalScore  Int?
  overrideNotes       String?
  overriddenByUserId  String?
  overriddenAt        DateTime?

  finalScore Int?
  passed     Boolean?

  submission TestSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([passed])
}

// Chat humano↔humano candidato↔RH por aplicación — NO extiende ChatSession
// (esa es user↔IA, semántica incompatible). Lazy-create: solo existe una vez
// que alguno de los dos lados manda el primer mensaje, y solo para
// aplicaciones a vacantes propias de empresa (source COMPANY).
model ApplicationThread {
  id              String   @id @default(cuid())
  applicationId   String   @unique
  companyId       String
  candidateUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  application   Application     @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  company       Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  candidateUser User            @relation("ThreadCandidate", fields: [candidateUserId], references: [id], onDelete: Cascade)
  messages      ThreadMessage[]

  @@index([companyId])
  @@index([candidateUserId])
}

model ThreadMessage {
  id           String    @id @default(cuid())
  threadId     String
  senderUserId String
  // true si lo mandó alguien del lado empresa — determina a qué sala NO
  // reenviar el evento realtime (el remitente ya lo tiene optimista) y
  // sirve para renderizar la burbuja del lado correcto sin otro join.
  fromCompany  Boolean
  content      String
  readAt       DateTime?
  createdAt    DateTime  @default(now())

  thread ApplicationThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User              @relation("ThreadMessageSender", fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

// Un usuario puede pertenecer a varias empresas (y seguir siendo candidato en
// otras). El rol determina permisos: OWNER puede gestionar miembros y cerrar
// la empresa; RECRUITER solo opera vacantes/pruebas/candidatos.
model CompanyMember {
  id        String            @id @default(cuid())
  companyId String
  userId    String
  role      CompanyMemberRole @default(RECRUITER)
  createdAt DateTime          @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([userId])
}

// ============================================================
// Vacantes e ingesta
// ============================================================

model Job {
  id            String    @id @default(cuid())
  source        JobSourceProvider
  externalId    String
  title         String
  company       String
  companyLogoUrl String?
  location      String?
  remote        Boolean   @default(false)
  description   String
  requirementsJson Json?  // extracción estructurada por IA (cacheada)
  salaryMin     Int?
  salaryMax     Int?
  currency      String?   @default("USD")
  atsType       String?
  // Nula para vacantes source=COMPANY: la aplicación queda dentro de Nab, no
  // hay sitio externo al que enviar al candidato.
  applyUrl      String?
  postedAt      DateTime?
  expiresAt     DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Solo poblado para source=COMPANY.
  companyId  String?
  // Solo poblado para source=COMPANY. Presencia = la aplicación requiere
  // tomar la prueba antes de considerarse completa (ver ApplicationsService.apply).
  techTestId String?

  // Embedding para matching semántico (pgvector). 1024 dims (Voyage voyage-3).
  embedding Unsupported("vector(1024)")?

  companyRef   Company?      @relation(fields: [companyId], references: [id])
  techTest     TechTest?     @relation(fields: [techTestId], references: [id])
  applications Application[]

  @@unique([source, externalId])
  @@index([isActive, postedAt])
  @@index([company])
  @@index([companyId, isActive])
}

model JobSource {
  id         String            @id @default(cuid())
  provider   JobSourceProvider
  config     Json // boards, filtros, credenciales por referencia
  lastSyncAt DateTime?
  status     SyncStatus        @default(IDLE)
  lastError  String?
  createdAt  DateTime          @default(now())

  @@unique([provider])
}

// ============================================================
// Aplicaciones y seguimiento
// ============================================================

model Application {
  id            String            @id @default(cuid())
  userId        String
  jobId         String
  status        ApplicationStatus @default(SAVED)
  method        ApplicationMethod @default(MANUAL)
  resumeId      String?
  coverLetterId String?
  matchScore    Int? // % de match calculado por IA
  notes         String?
  submittedAt   DateTime?
  autoApplied   Boolean           @default(false) // true si la aplicó el agente de auto-aplicación, no el usuario
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  job         Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  resume      Resume?      @relation(fields: [resumeId], references: [id])
  coverLetter CoverLetter? @relation(fields: [coverLetterId], references: [id])
  events      ApplicationEvent[]
  testSubmission TestSubmission?
  thread      ApplicationThread?

  @@unique([userId, jobId])
  @@index([userId, status])
  @@index([userId, autoApplied, submittedAt])
}

model ApplicationEvent {
  id            String   @id @default(cuid())
  applicationId String
  eventType     String // "created" | "status_changed" | "email_received" | ...
  payload       Json?
  createdAt     DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId, createdAt])
}

// ============================================================
// Facturación y créditos
// ============================================================

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  plan                 Plan
  creditsPerCycle      Int
  status               SubscriptionStatus @default(INCOMPLETE)
  currentPeriodEnd     DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Libro mayor auditable de créditos. El saldo es la suma de deltas.
model CreditLedger {
  id        String       @id @default(cuid())
  userId    String
  delta     Int // positivo = grant, negativo = consumo
  reason    CreditReason
  refId     String? // id de la Application / Resume / evento relacionado
  createdAt DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, reason, refId])
  @@index([userId, createdAt])
}

// ============================================================
// Chatbot (soporte + career coach)
// ============================================================

model ChatSession {
  id          String      @id @default(cuid())
  userId      String
  contextType ChatContext
  title       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([userId, createdAt])
}

model ChatMessage {
  id           String   @id @default(cuid())
  sessionId    String
  role         ChatRole
  content      String
  toolCallsJson Json?
  tokens       Int?
  createdAt    DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

// ============================================================
// Base de conocimiento del bot de soporte (RAG)
// ============================================================

model HelpArticle {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  content   String
  category  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  embedding Unsupported("vector(1024)")?
}

// Guías editoriales internas (RAG, mismo patrón que HelpArticle) — la
// tercera fuente citable de la rúbrica de pruebas técnicas (junto a
// role_spec y standard). Retrieval top-5 por similitud vía pgvector; el
// pipeline de generación inyecta solo las guías recuperadas y un guideId
// citado por el LLM solo verifica si pertenece a ESE set (nunca por
// confianza ciega en el id que el modelo diga).
// `content` se interpola sin sanitizar/truncar en el prompt de generación
// (tech-test-generation.service.ts) porque hoy solo lo escribe el seed de
// Nab — si en el futuro se agrega un endpoint de admin para editar guías,
// hay que revisar esa interpolación (truncado + escape de delimitadores,
// mismo trato que sanitizeCandidateAnswer) antes de que el contenido deje
// de ser 100% confiable.
model InterviewGuide {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  content   String
  category  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  embedding Unsupported("vector(1024)")?
}
