# ==============================================================
# Nab — Variables de entorno (copiar a .env y completar valores)
# ==============================================================

# --- General ---
NODE_ENV=development

# En producción (NODE_ENV=production), si no hay ANTHROPIC_API_KEY/
# VOYAGE_API_KEY o ninguna fuente de vacantes configurada, la API y los
# workers NO arrancan a menos que pidas el modo mock explícitamente:
AI_MOCK=false
INGEST_MOCK=false

# --- docker-compose.yml / docker-compose.prod.yml (credenciales de Postgres) ---
POSTGRES_USER=nab
POSTGRES_PASSWORD=nab
POSTGRES_DB=nab
# true solo para poblar datos demo (nunca en un despliegue con usuarios reales).
SEED_DEMO=false

# --- Solo docker-compose.prod.yml (VPS) ---
# Cuenta/organización de GitHub dueña de las imágenes en GHCR.
GHCR_OWNER=
# Tag de imagen a desplegar (la pisa el workflow de CD con sha-<commit>).
GHCR_IMAGE_TAG=latest
# Dominio de la API servido por Caddy (TLS automático), p.ej. api.nab.app
API_DOMAIN=

# --- Base de datos (Postgres 16 + pgvector) ---
# docker-compose.dev expone Postgres en el host en el puerto 5433 (para no
# chocar con un Postgres local en 5432). Dentro de compose el host es "postgres".
DATABASE_URL=postgresql://nab:nab@localhost:5433/nab?schema=public

# --- Redis (colas BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- API (NestJS) ---
API_PORT=4000
API_PUBLIC_URL=http://localhost:4000
WEB_PUBLIC_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# --- Autenticación (Auth.js v5 / JWT compartido) ---
# Genera un secreto: openssl rand -base64 32
NEXTAUTH_SECRET=cambia-esto-por-un-secreto-largo
NEXTAUTH_URL=http://localhost:3000
JWT_SECRET=cambia-esto-por-otro-secreto-largo
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- IA (Claude / Anthropic) ---
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL_GENERATION=claude-sonnet-5
AI_MODEL_FAST=claude-haiku-4-5-20251001
# Embeddings (Voyage AI). Dejar vacío para usar modo mock en dev.
VOYAGE_API_KEY=

# --- Pagos (Stripe) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ULTRA=price_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Almacenamiento S3 (MinIO en dev) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=nab-uploads
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio12345
S3_FORCE_PATH_STYLE=true

# --- Email (Mailpit en dev: SMTP sin auth) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Nab <no-reply@nab.app>"

# --- Fuentes de vacantes (dejar vacío = modo mock en dev) ---
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
JSEARCH_RAPIDAPI_KEY=
# Listas separadas por coma de "boards" públicos por empresa:
GREENHOUSE_BOARDS=airbnb,stripe,figma
LEVER_BOARDS=netflix,plaid

# --- Observabilidad (Sentry, opcional — sin DSN el SDK queda inactivo) ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Solo necesarios para subir source maps al hacer build de la web (opcional).
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# --- Backups de Postgres (bucket R2 dedicado, distinto de S3_*) ---
BACKUP_S3_ENDPOINT=
BACKUP_S3_BUCKET=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=

# --- Frontend (Next.js) ---
# URL interna que usa la web para llamar a la API desde el servidor
# (server actions, server components). En Docker: http://api:4000
API_URL=http://localhost:4000
# URL pública de la API (expuesta al navegador)
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_NAME=Nab
# URL pública del sitio (para sitemap.xml/robots.txt); en prod: https://nab.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
