# Variables EXPO_PUBLIC_* se inlinean en el bundle (visibles en el cliente).
# En dispositivo físico, "localhost" no resuelve a tu máquina: usa la IP de
# tu red local (ej. http://192.168.1.20:4000) o un túnel (ngrok/expo tunnel).
EXPO_PUBLIC_API_URL=http://localhost:4000
EXPO_PUBLIC_WS_URL=http://localhost:4000
