// Nab — Esquema de base de datos (Prisma + PostgreSQL 16 + pgvector)
// Ver plan de arquitectura para el diseño completo.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ============================================================
// Enums
// ============================================================

enum Plan {
  FREE
  BASIC
  PRO
  ULTRA
}

enum RemotePreference {
  ANY
  REMOTE
  HYBRID
  ONSITE
}

enum ApplicationStatus {
  SAVED
  APPLIED
  VIEWED
  INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
}

enum ApplicationMethod {
  AUTO
  MANUAL
  EXTERNAL
}

enum CreditReason {
  SUBSCRIPTION_GRANT
  APPLICATION
  GENERATION
  REFUND
  ADMIN
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  TRIALING
}

enum ChatContext {
  SUPPORT
  CAREER_COACH
}

enum ChatRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

enum JobSourceProvider {
  GREENHOUSE
  LEVER
  ADZUNA
  JSEARCH
  MOCK
}

enum SyncStatus {
  IDLE
  RUNNING
  ERROR
}

// ============================================================
// Usuario, perfil y autenticación
// ============================================================

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String?
  passwordHash    String?
  avatarUrl       String?
  plan            Plan      @default(FREE)
  creditsRemaining Int      @default(5) // caché denormalizado; la fuente de verdad es CreditLedger
  emailVerifiedAt DateTime?
  expoPushToken   String?   // token de Expo Notifications (app móvil, Fase 7)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  profile            Profile?
  resumes            Resume[]
  coverLetters       CoverLetter[]
  applications       Application[]
  subscription       Subscription?
  creditLedger       CreditLedger[]
  chatSessions       ChatSession[]
  integrations       Integration[]
  refreshTokens      RefreshToken[]
  verificationTokens VerificationToken[]

  @@index([email])
}

enum VerificationTokenType {
  EMAIL_VERIFY
  PASSWORD_RESET
}

// Refresh tokens con rotación: se guarda solo el hash para poder revocar.
model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Tokens de un solo uso para verificación de email y reset de contraseña.
model VerificationToken {
  id        String                @id @default(cuid())
  userId    String
  tokenHash String                @unique
  type      VerificationTokenType
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime              @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
}

model Profile {
  id               String           @id @default(cuid())
  userId           String           @unique
  headline         String?
  summary          String?
  skills           String[]
  experienceJson   Json?
  educationJson    Json?
  locations        String[]
  desiredRoles     String[]
  salaryMin        Int?
  salaryMax        Int?
  remotePreference RemotePreference @default(ANY)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Integration {
  id          String   @id @default(cuid())
  userId      String
  provider    String // "linkedin" | "indeed" | ...
  oauthTokens Json
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

// ============================================================
// Documentos: CV y cartas de presentación
// ============================================================

model Resume {
  id              String   @id @default(cuid())
  userId          String
  title           String
  contentJson     Json
  isBase          Boolean  @default(false)
  generatedFromId String? // id del Resume base del que se derivó
  jobId           String? // vacante para la que se personalizó
  fileUrl         String? // PDF en S3
  atsScore        Int?
  model           String? // modelo de IA usado en la generación
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications Application[]

  @@index([userId])
}

model CoverLetter {
  id        String   @id @default(cuid())
  userId    String
  jobId     String?
  content   String
  tone      String   @default("professional")
  model     String?
  createdAt DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications Application[]

  @@index([userId])
}

// ============================================================
// Vacantes e ingesta
// ============================================================

model Job {
  id            String    @id @default(cuid())
  source        JobSourceProvider
  externalId    String
  title         String
  company       String
  companyLogoUrl String?
  location      String?
  remote        Boolean   @default(false)
  description   String
  requirementsJson Json?  // extracción estructurada por IA (cacheada)
  salaryMin     Int?
  salaryMax     Int?
  currency      String?   @default("USD")
  atsType       String?
  applyUrl      String
  postedAt      DateTime?
  expiresAt     DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Embedding para matching semántico (pgvector). 1024 dims (Voyage voyage-3).
  embedding Unsupported("vector(1024)")?

  applications Application[]

  @@unique([source, externalId])
  @@index([isActive, postedAt])
  @@index([company])
}

model JobSource {
  id         String            @id @default(cuid())
  provider   JobSourceProvider
  config     Json // boards, filtros, credenciales por referencia
  lastSyncAt DateTime?
  status     SyncStatus        @default(IDLE)
  lastError  String?
  createdAt  DateTime          @default(now())

  @@unique([provider])
}

// ============================================================
// Aplicaciones y seguimiento
// ============================================================

model Application {
  id            String            @id @default(cuid())
  userId        String
  jobId         String
  status        ApplicationStatus @default(SAVED)
  method        ApplicationMethod @default(MANUAL)
  resumeId      String?
  coverLetterId String?
  matchScore    Int? // % de match calculado por IA
  notes         String?
  submittedAt   DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  job         Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  resume      Resume?      @relation(fields: [resumeId], references: [id])
  coverLetter CoverLetter? @relation(fields: [coverLetterId], references: [id])
  events      ApplicationEvent[]

  @@unique([userId, jobId])
  @@index([userId, status])
}

model ApplicationEvent {
  id            String   @id @default(cuid())
  applicationId String
  eventType     String // "created" | "status_changed" | "email_received" | ...
  payload       Json?
  createdAt     DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId, createdAt])
}

// ============================================================
// Facturación y créditos
// ============================================================

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  plan                 Plan
  creditsPerCycle      Int
  status               SubscriptionStatus @default(INCOMPLETE)
  currentPeriodEnd     DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Libro mayor auditable de créditos. El saldo es la suma de deltas.
model CreditLedger {
  id        String       @id @default(cuid())
  userId    String
  delta     Int // positivo = grant, negativo = consumo
  reason    CreditReason
  refId     String? // id de la Application / Resume / evento relacionado
  createdAt DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// ============================================================
// Chatbot (soporte + career coach)
// ============================================================

model ChatSession {
  id          String      @id @default(cuid())
  userId      String
  contextType ChatContext
  title       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([userId, createdAt])
}

model ChatMessage {
  id           String   @id @default(cuid())
  sessionId    String
  role         ChatRole
  content      String
  toolCallsJson Json?
  tokens       Int?
  createdAt    DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

// ============================================================
// Base de conocimiento del bot de soporte (RAG)
// ============================================================

model HelpArticle {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  content   String
  category  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  embedding Unsupported("vector(1024)")?
}
